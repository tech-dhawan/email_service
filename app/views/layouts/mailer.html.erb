<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <style>
      body {
        background-color: #F6F6F6; /* Light grey backdrop */
        margin: 0;
        padding: 40px 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #FFFFFF; /* Pure white card */
        border: 1px solid #E0E0E0;
        border-radius: 4px;
        overflow: hidden;
      }
      .email-body {
        padding: 40px;
        color: #000000;
      }
      .email-footer {
        padding: 20px;
        text-align: center;
        font-size: 12px;
        color: #999999;
      }
    </style>
  </head>
  <body>
    <div class="email-container">
      <div class="email-body">
        <%= yield %>
      </div>
      <div class="email-footer">
        &copy; <%= Time.current.year %> Your Company Name
      </div>
    </div>
  </body>
</html>